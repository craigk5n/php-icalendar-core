{
    "name": "craigk5n/php-icalendar-core",
    "description": "RFC 5545 compliant PHP library for iCalendar parsing and writing",
    "license": "MIT",
    "type": "library",
    "version": "1.1.5",
    "homepage": "https://github.com/craigk5n/php-icalendar-core",
    "keywords": ["icalendar", "ics", "rfc5545", "calendar", "parser", "writer"],
    "support": {
        "issues": "https://github.com/craigk5n/php-icalendar-core/issues",
        "source": "https://github.com/craigk5n/php-icalendar-core"
    },
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "infection/infection": "^0.29",
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^10.0",
        "vimeo/psalm": "^5.0 || ^6.0"
    },
    "autoload": {
        "psr-4": {
            "Icalendar\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Icalendar\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "phpstan": "vendor/bin/phpstan analyse src --level=9",
        "psalm": "vendor/bin/psalm",
        "infection": "vendor/bin/infection --threads=4"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "infection/extension-installer": true
        }
    }
}
